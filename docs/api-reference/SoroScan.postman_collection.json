{
  "info": {
    "name": "SoroScan API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "SoroScan REST and GraphQL API collection for Postman."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "contractId",
      "value": "CABC123..."
    }
  ],
  "item": [
    {
      "name": "Authenticate",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"<email-or-username>\",\n  \"password\": \"<password>\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/token/"
        }
      }
    },
    {
      "name": "List Contracts",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ingest/contracts/"
        }
      }
    },
    {
      "name": "List Events",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ingest/events/"
        }
      }
    },
    {
      "name": "Search Events",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ingest/events/search/"
        }
      }
    },
    {
      "name": "Create Webhook",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"target_url\": \"https://example.com/webhook\",\n  \"event_filter\": {\n    \"contract_id\": \"{{contractId}}\"\n  },\n  \"enabled\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/ingest/webhooks/"
        }
      }
    },
    {
      "name": "GraphQL Query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"query { contracts(isActive: true) { contractId name eventCount } }\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/graphql/"
        }
      }
    }
  ]
}
